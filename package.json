{
  "name": "dns-forge-addon",
  "version": "0.9.3",
  "description": "Firefox extension for managing NextDNS blocklists and allowlists",
  "main": "background.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "web-ext build --overwrite-dest --filename \"{name}-{version}.xpi\" --ignore-files \"tests/**\" \"node_modules/**\" \".git/**\" \".github/**\" \".vscode/**\" \"package.json\" \"package-lock.json\" \"jest.setup.js\" \".gitignore\" \"README.md\" \"CHANGELOG.md\" \".gemini/**\" \"*.skill\" \"**/*.test.js\""
  },
  "devDependencies": {
    "@testing-library/dom": "^9.3.1",
    "@testing-library/jest-dom": "^6.1.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "latest",
    "jest-webextension-mock": "latest",
    "web-ext": "^8.0.0"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  }
}
