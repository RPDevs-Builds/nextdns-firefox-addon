{
  "name": "dns-forge-addon",
  "version": "0.9.3",
  "description": "Firefox extension for managing NextDNS blocklists and allowlists",
  "main": "src/background/main.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "lint:addon": "NODE_OPTIONS='--max-old-space-size=4096' node .tools/addons-linter/bin/addons-linter web-ext-artifacts/dns_forge-0.9.3.xpi",
    "build": "web-ext build --overwrite-dest --filename \"{name}-{version}.xpi\" --ignore-files \"tests/**\" \"node_modules/**\" \".git/**\" \".github/**\" \".vscode/**\" \"package.json\" \"package-lock.json\" \"jest.setup.js\" \".gitignore\" \"README.md\" \"CHANGELOG.md\" \"LICENSE\" \".gemini/**\" \"*.skill\" \"**/*.test.js\" \"*-results.json\" \"reports/**\"",
    "bump": "node scripts/bump_version.js"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@testing-library/dom": "^9.3.1",
    "@testing-library/jest-dom": "^6.1.4",
    "addons-linter": "file:.tools/addons-linter",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "latest",
    "jest-webextension-mock": "latest",
    "node-fetch": "2.6.11",
    "web-ext": "^8.0.0"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testMatch": [
      "**/tests/?(*.)+(spec|test).[tj]s?(x)"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.tools/"
    ]
  }
}
