{
  "manifest_version": 3,
  "name": "DNS Forge",
  "version": "0.9.3",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "menus",
    "webRequest",
    "webRequestBlocking"
  ],
  "optional_permissions": [
    "notifications"
  ],
  "host_permissions": [
    "https://api.nextdns.io/*",
    "https://test.nextdns.io/*",
    "<all_urls>"
  ],
  "optional_host_permissions": [],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-48.png"
  },
  "background": {
    "scripts": ["src/storage.js", "src/apiClient.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://my.nextdns.io/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/domSelectors.json", "data/blocks_meta.json"],
      "matches": ["https://my.nextdns.io/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{56fda99b-4dd4-4a4a-a413-00ff1c2cffd8}"
    }
  },
  "sidebar_action": {
    "default_title": "DNS Forge",
    "default_panel": "popup.html?mode=sidebar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  }
}
